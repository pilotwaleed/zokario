# =====================================================================
# Zokario — backend environment variables (.env.example)
# =====================================================================
# The static site itself uses NONE of these. They exist for the backend
# pieces that replace the /* @API */ demo rails (grep "@API" to see every
# swap point in the code). Copy this file to ".env" ON THE SERVER, above
# public_html (never inside the webroot), and fill in real values.
# NEVER commit a real .env to git.
# Each variable notes the exact swap point it serves.
# =====================================================================

# ---- Payments: Stripe -------------------------------------------------
# Swap points: checkout.html (.stripe-box "@API Stripe Elements"),
# stripe-backend/create-checkout-session.php, stripe-backend/webhook.php.
# Also gates the Gilded membership / Patron / Atelier flows
# (js/community.js ZKSub.start, ZKSupport.give, ZKAtelier.submit @API payment).
STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_ME   # browser-side key (safe to expose)
STRIPE_SECRET_KEY=sk_live_REPLACE_ME        # server only
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME      # server only, verifies webhook events

# ---- Payments: regional cards (mada / BENEFIT) — pending owner decision
# The footer shows mada and BENEFIT badges. Stripe alone does not cover
# these; a local PSP (e.g. Tap Payments or a Bahrain bank gateway) is
# needed, or the badges must be removed at launch. Uncomment when decided.
# LOCAL_PSP_PUBLIC_KEY=
# LOCAL_PSP_SECRET_KEY=                     # server only
# LOCAL_PSP_WEBHOOK_SECRET=                 # server only

# ---- Transactional email ---------------------------------------------
# Swap points: account.html askVerify ("@API real email"),
# js/auth.js requestReset ("@API: server emails the code"),
# js/app.js ZKNews.request ("@API real confirmation email"),
# js/app.js zkReceipt ("@API invoices") + stripe-backend/webhook.php step 3
# (receipt + download links after purchase).
EMAIL_API_KEY=                              # Postmark / Resend / SES api key
EMAIL_FROM=no-reply@zokario.com             # verified sender (set SPF + DKIM on the domain)

# ---- Newsletter service (optional) -------------------------------------
# Swap point: js/app.js ZKNews ("@API newsletter service") and the
# communication-preference writes in account.html. Can reuse the email
# provider above, or a dedicated ESP.
# NEWSLETTER_API_KEY=

# ---- Contact form delivery ---------------------------------------------
# Swap point: contact.html ~line 233 ("@API: POST /contact, swap for your
# email service or form endpoint"). Until this exists, messages stay in the
# visitor's own browser and never reach the owner.
CONTACT_WEBHOOK=                            # Formspree / worker / endpoint URL

# ---- Protected file delivery (TOP LAUNCH BLOCKER) -----------------------
# Swap points: js/app.js zkDownload, js/data.js pdf: paths,
# stripe-backend/webhook.php step 3. Paid PDFs must move out of public
# /files/ and be served via signed, expiring URLs tied to a purchase.
STORAGE_BUCKET=                             # private bucket / non-public directory for the PDFs
DOWNLOAD_SIGNING_SECRET=                    # signs the expiring download links
DOWNLOAD_URL_TTL=86400                      # seconds a signed link stays valid

# ---- Auth, sessions, roles (admin auth) --------------------------------
# Swap points: js/auth.js ("@API: POST /auth/signup|login, PATCH /me,
# POST /me/password"), js/community.js ZK_OWNER_EMAILS ("@API server-side
# role check") — the Publisher's Desk role must be enforced server-side.
SESSION_SECRET=                             # signs httpOnly session cookies / JWTs
OWNER_EMAIL=owner@zokario.com               # server-side owner allowlist (use a dedicated
                                            # alias, not a personal inbox — audit item L14)

# ---- Analytics + consent log (only if/when analytics is added) ----------
# Swap points: js/app.js "@API: gate analytics ... with ZKConsent.allows()"
# and "@API: forward the consent receipt". NO analytics ships today and the
# privacy policy says so — any future loader MUST be consent-gated first.
# ANALYTICS_ID=
# CONSENT_LOG_WEBHOOK=

# ---- Community realtime + notifications (optional, post-launch) ---------
# Swap points: js/community.js chat write ("@API websocket"),
# desk log ("@API push notification"), vault ("@API real storage" for
# owner-uploaded covers/PDFs and Atelier file uploads).
# CHAT_WS_URL=
# NOTIFY_WEBHOOK=
# UPLOADS_BUCKET=

# ---- Supplier APIs -------------------------------------------------------
# Not applicable to this repo. TrendyTech supplier credentials (TRENDYTECH_*)
# belong to the separate trendytech-store repository; Zokario is a publishing
# house with no supplier/dropship touchpoints — nothing to configure here.
